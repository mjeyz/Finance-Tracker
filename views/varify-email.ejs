<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Varify your Email</title>
    <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"/>
    <link rel="stylesheet" href="css/styles.css"/>
    <link rel="stylesheet" href="css/login.css"/>

    <link
            href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
            rel="stylesheet"/>

    <!-- Font Awesome for icons -->
    <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />

</head>
<body style="display: flex;justify-content: center">

<div class="varify-email-container" id="varifyEmailContainer">

    <% if (error && error.length > 0) { %>
        <div class="flash-stack">
            <% error.forEach(function (msg) { %>
                <div class="flash-message flash-error"><%= msg %></div>
            <% }) %>
        </div>
    <% } %>
    <% if (success && success.length > 0) { %>
        <div class="flash-stack">
            <% success.forEach(function (msg) { %>
                <div class="flash-message flash-success"><%= msg %></div>
            <% }) %>
        </div>
    <% } %>

    <div class="flash-message flash-error" id="verificationMessage" style="display:none;"></div>

    <form class="varify-email-form" method="POST" action="/varify-email">
        <h1 class="varify-heading">Please varify your Email</h1>
        <div class="varify-section email-section active" id="emailSection">
            <div class="form-group">
                <label for="email" style="color: #5c636a">Enter your Email</label>
                <input type="email" id="email" placeholder="example@gmail.com" name="email" required>
            </div>
            <button type="submit" class="submit-btn" id="sendCodeBtn">Send Code</button>

        </div>

        <div class="varify-section code-section" id="codeSection">
            <div class="form-group">
                <label for="varifyEmail" style="color: #5c636a">Enter your code</label>
                <input type="text" id="varifyEmail" placeholder="e.g. 123456" name="code" inputmode="numeric" autocomplete="one-time-code">
            </div>
            <button type="submit" class="submit-btn" style="margin-bottom: 1rem">Submit Code</button>

            <div class="action-group">
                <div>
                    <span class="timer" id="timer">00:00</span>
                </div>

                <div>
                    <a class="resend-code" id="resendCode">Resend code</a>
                </div>
            </div>
        </div>
    </form>

    <script>
        const sendCodeBtn = document.getElementById("sendCodeBtn");
        const codeSection = document.getElementById("codeSection");
        const emailSection = document.getElementById("emailSection");
        const verificationMessage = document.getElementById("verificationMessage");
        const emailInput = document.getElementById("email");
        const form = document.querySelector(".varify-email-form");

        function setActive() {
            emailSection.classList.remove("active");
            codeSection.classList.add("active");
        }

        function showMessage(message, type) {
            verificationMessage.textContent = message;
            verificationMessage.className = `flash-message ${type === "success" ? "flash-success" : "flash-error"}`;
            verificationMessage.style.display = "block";
        }


        sendCodeBtn.addEventListener("click", async function(event) {
            event.preventDefault();

            const email = emailInput.value.trim();
            if (!email) {
                showMessage("Please enter your email address.", "error");
                return;
            }

            try {
                const response = await fetch("/send-otp", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/x-www-form-urlencoded"
                    },
                    body: new URLSearchParams({email})
                });

                const data = await response.json();

                if (!response.ok || !data.success) {
                    showMessage(data.error || "Unable to send verification code.", "error");
                    return;
                }

                showMessage("Verification code sent. Check your email.", "success");
                setActive();
            } catch (error) {
                showMessage("Unable to send verification code right now.", "error");
            }
        });

        form.addEventListener("submit", function () {
            verificationMessage.style.display = "none";
        });

    </script>

</div>
</body>
</html>