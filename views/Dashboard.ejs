<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Finance Tracker</title>
    <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"/>
    <link rel="stylesheet" href="css/styles.css"/>
    <link
            href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css"
            rel="stylesheet"/>

    <!-- Font Awesome for icons -->
    <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
</head>
<body>
<div class="flash-stack page-flash-stack">
    <% if (error && error.length > 0) { %>
        <% error.forEach(function (msg) { %>
            <div class="flash-message flash-error"><%= msg %></div>
        <% }) %>
    <% } %>
    <% if (success && success.length > 0) { %>
        <% success.forEach(function (msg) { %>
            <div class="flash-message flash-success"><%= msg %></div>
        <% }) %>
    <% } %>
    <% if (info && info.length > 0) { %>
        <% info.forEach(function (msg) { %>
            <div class="flash-message flash-info"><%= msg %></div>
        <% }) %>
    <% } %>
</div>


<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
    <i class="sidebar-link"> <span style="color: #4f46e5;">Fin</span>Track </i>
    </div>
    <nav class="sidebar-manu">
        <a class="nav-link">
            <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    fill="currentColor"
                    viewBox="0 0 24 24">
                <path
                        d="m10.94,15.5c.71.46,1.65.27,2.12-.44,0,0,0,0,0,0l3.96-6.04s0-.02,0-.03c0-.02-.03-.02-.04-.01l-6.04,3.96c-.71.46-.91,1.41-.44,2.12.12.18.27.33.44.44Z"
                ></path>
                <path
                        d="m5.08,20h13.85c.71,0,1.37-.37,1.72-.97,0,0,0,0,0,0,1.09-1.87,1.54-4.02,1.29-6.2-.52-4.58-4.23-8.26-8.81-8.77-2.84-.31-5.69.6-7.8,2.49-2.11,1.9-3.33,4.61-3.33,7.45,0,1.77.47,3.51,1.36,5.03.35.6,1.01.97,1.72.97Zm1.58-11.96c1.49-1.33,3.35-2.04,5.33-2.04.3,0,.61.02.92.05,3.66.4,6.62,3.35,7.04,7.01.2,1.74-.15,3.45-1.02,4.95h0s-13.84.02-13.84.02c-.71-1.22-1.08-2.61-1.08-4.02,0-2.27.97-4.44,2.66-5.96Z"
                ></path>
            </svg>
            Dashboard
        </a>
        <a class="nav-link">
            <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    fill="currentColor"
                    viewBox="0 0 24 24">
                <!--Boxicons v3.0.8 https://boxicons.com | License  https://docs.boxicons.com/free-->
                <path
                        d="M21 11h-3V5c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v13c0 1.65 1.35 3 3 3h14c1.65 0 3-1.35 3-3v-6c0-.55-.45-1-1-1M5 19c-.55 0-1-.45-1-1V5h12v13a3 3 0 0 0 .17 1zm15-1c0 .55-.45 1-1 1s-1-.45-1-1v-5h2z"></path>
                <path d="M6 7h8v2H6zm0 4h8v2H6zm5 4h3v2h-3z"></path>
            </svg>
            Transaction
        </a>
        <a class="nav-link">
            <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    fill="currentColor"
                    viewBox="0 0 24 24">
                <!--Boxicons v3.0.8 https://boxicons.com | License  https://docs.boxicons.com/free-->
                <path
                        d="M19 4h-2V2h-2v2H9V2H7v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2M5 20V8h14V6v14z"></path>
                <path
                        d="m11 14.59-2.29-2.3-1.42 1.42 3.71 3.7 5.71-5.7-1.42-1.42z"></path>
            </svg>
            Events
        </a>
        <a class="nav-link">
            <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    fill="currentColor"
                    viewBox="0 0 24 24">
                <!--Boxicons v3.0.8 https://boxicons.com | License  https://docs.boxicons.com/free-->
                <path
                        d="M5 21h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2m0-2v-5h2.38l.72 1.45a1 1 0 0 0 .89.55h6c.38 0 .73-.21.89-.55L16.6 14h2.38v5h-14Zm0-7v-2h14v2h-3c-.38 0-.73.21-.89.55L14.39 14H9.63l-.72-1.45a1 1 0 0 0-.89-.55h-3Zm14-7v3H5V5z"></path>
            </svg>
            saving
        </a>
    </nav>

    <div style="border-top: 1px solid #949b9e; padding-top: 1rem;" class="logout-sidebar-btn">
        <a class="nav-link" href="/logout">
            <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    fill="currentColor"
                    viewBox="0 0 24 24">
                <!--Boxicons v3.0.8 https://boxicons.com | License  https://docs.boxicons.com/free-->
                <path d="M9 13h7v-2H9V7l-6 5 6 5z"></path>
                <path
                        d="M19 3h-7v2h7v14h-7v2h7c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2">
                </path>
            </svg>
            Logout
        </a>
    </div>
</aside>


<!--TODO 2: fix top navbar behaviour on small screen-->
<header class="header top-nav">
    <button class="toggle-btn" id="toggleBtn" aria-label="Toggle sidebar">
    <i class="fas fa-bars"></i>
    </button>

    <!-- Search placeholder -->
    <div class="search-group">
        <i class="fas fa-search icon"></i>
        <input
                type="search"
                id="dashboardSearch"
                placeholder="Search transactions, events, or goals..."
                name="search"
                class="search-input"
                aria-label="Search dashboard items"/>
    </div>
    <div
            class="user-menu"
            style="display: flex; align-items: center; gap: 1rem">
        <div class="notifications">
            <i class="bx bx-bell" style="font-size: 1.25rem; color: #6b7280"></i>
        </div>
        <div
                class="profile"
                style="display: flex; align-items: center; gap: 0.5rem">
            <div
                    style="
              width: 32px;
              height: 32px;
              background: #e0e7ff;
              color: #4f46e5;
              border-radius: 50%;
              display: flex;
              align-items: center;
              justify-content: center;
              font-weight: bold;
            ">

                <%= user.name[0].toUpperCase() %>
            </div>
            <span style="font-weight: 500"><%= user.email %></span>
        </div>
    </div>
</header>


<main class="main-content">

    <h1 class="dashboard-heading">Dashboard</h1>
    <p class="dashboard-subtitle">Your financial overview at a glance</p>

    <div class="update-income-cantainer">
        <button class="update-income-btn" id="updateIncomeBtn"><i class="fa-solid fa-plus"></i> Update income</button>
    </div>


    <div class="update-income-overlay" id="updateIncomeOverlay">
        <div class="update-income-model">

            <div class="update-income-header">
                <div class="title"><i class="fa-solid fa-plus"></i> Add or update income</div>
                <button class="close-btn" id="incomeCloseBtn" aria-label="Close">
                <i class="fas fa-times"></i>
            </button>
            </div>


            <div class="update-income-model-body">
                <form class="update-income-form" id="incomeForm" method="POST" data-submit-route="/api/update/income">

                    <div class="form-group">
                        <label for="incomeInput">Income</label>
                        <input type="text" placeholder="20000" name="income" id="incomeInput">
                    </div>

                    <div class="form-group">
                        <label for="incomeInput">Expenses</label>
                        <input type="text" placeholder="20000" name="expense" id="incomeInput">
                    </div>

                    <div class="form-action">
                    <button class="btn btn-secondary" id="incomeCancelModel" type="button">Cancel</button>
                    <button class="btn btn-primary" id="incomeSubmitBtn" type="submit">Submit</button>
                </div>
                </form>


            </div>
        </div>
    </div>

    <div class="status">
        <div class="stat-card total-income">
            <span class="card-subtitle">Total Income</span>
            <% if (user.income) { %>
                <p class="amount"><%= user.income %> PKR</p>
            <% } else { %>
                <p class="amount">0 PKR</p>
            <% } %>
        </div>
        <div class="stat-card current-balance">
            <span class="card-subtitle">Current Balance</span>
            <p class="amount">PKR 0</p>
        </div>
        <div class="stat-card expenses">
            <span class="card-subtitle">Expenses</span>
            <% if (user.expenses) { %>
                <p class="amount"><%= user.expenses %></p>
            <% } else { %>
                <p class="amount">0 PKR</p>
            <% } %>
        </div>
    </div>

    <div class="button-group">
        <button class="tab-btn transaction-btn active" id="transactionBtn">
            Transaction
        </button>
        <button class="tab-btn envent-btn" id="eventBtn">Upcoming Event</button>
        <button class="tab-btn saving-btn" id="savingBtn">Saving</button>
    </div>

    <div class="display-panel">
        <div class="list-header">
            <h3 id="dynamicTitle">Transaction History</h3>
        </div>
        <div id="listContainer" class="listContainer active">


            <!--  Transaction List-->
            <div class="list-section transaction-list active" id="transactionList">
                <% if ( transaction.length > 0 ) { %>
                    <% for (const tx of transaction) { %>
                        <div class="transaction-item" data-id="<%= tx.id %>">
                            <div style="width: 42px; height: 42px; background: #E0E7FF; border-radius: 20%; display: flex; align-items: center; justify-content: center; font-weight: bold;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                     fill="#9b1212" viewBox="0 0 24 24">
                                    <path d="M13 18v-6h4l-5-6-5 6h4v6z"></path>
                                </svg>
                            </div>
                            <div style="flex: 1; min-width: 0;">
                                <p style="margin: 0; font-size: 14px; font-weight: 500; color: #3B3B3B;"><%= tx.description %></p>
                                <span style="font-size: 12px; color: #888;"><%= tx.date %></span>
                            </div>


                            <!-- 3. Amount -->
                            <span style="white-space: nowrap; color: #c0786a; font-size: 14px; font-weight: 500;"> <%= tx.amount %></span>
                            <div class="delete" id="deleteBtn">
                                <i class="fa-regular fa-trash-can trash-icon"></i>
                            </div>
                        </div>
                    <% } %>
                <% } else { %>
                    <div class="empty-message">No Transaction History Found</div>
                <% } %>
            </div>

            <!--  Events List-->
            <div class="list-section events-list" id="eventList">
                <% if ( events.length > 0 ) { %>
                    <% events.forEach( ev => { %>
                        <div class="event-item" data-id="<%= ev.id %>">
                            <div style="flex: 1; min-width: 0; border-left: 5px solid orangered; border-radius: 4px; padding-left: 10px">
                                <p style="margin: 0; font-size: 14px;font-weight: 500; color: #3B3B3B">
                                    <%= ev.name %></p>
                                <span style="font-size: 12px; color: #888;"><%= ev.date %></span>
                            </div>
                            <div style="white-space: nowrap;">
                                <span style="font-size: 14px; font-weight: 500; color: orange">RS 400</span>
                                <p style="font-size: 12px;">Mid priority</p>
                            </div>
                            <div class="delete" id="deleteBtn">
                                <i class="fa-regular fa-trash-can trash-icon"></i>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-message">No Events Found</div>
                <% } %>
            </div>

            <!--  Saving List-->
            <div class="list-section saving-goals" id="savingList">
                <% if ( saving.length > 0 ) { %>
                    <% saving.forEach( sv => { %>

                        <%
                            const percent = (sv.savedamount / sv.targetamount) * 100;
                            const percentRounded = Math.min(100, Math.floor(percent));
                        %>

                        <div class="goal-card" data-id="<%= sv.id %>">
                            <div class="goal-header">
                                <span class="goal-name"><%= sv.goal %></span>
                                <span class="goal-pct"><%= percentRounded %>%</span>
                            </div>
                            <div class="progress-track">
                                <div class="progress-fill" style="width: <%= percentRounded %>%"></div>
                            </div>
                            <div class="goal-footer">
                                <span>Rs <%= sv.savedamount %> saved</span>
                                <span>Goal: Rs <%= sv.targetamount %></span>
                                <div class="delete" id="deleteBtn">
                                    <i class="fa-regular fa-trash-can trash-icon"></i>
                                </div>
                            </div>

                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="empty-message">No Saving Found</div>
                <% } %>
            </div>
        </div>
        <button class="add-transaction" id="addTransaction">+ Add Transaction</button>


        <div class="overlay" id="overlay">

            <div class="model" id="model">


                <div class="model-header" id="modelHeader">
                    <div class="title" id="modalTitle">
                        Add Transaction
                    </div>
                    <button class="close-btn" id="closeModalBtn" aria-label="Close">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                <div class="model-body" id="modelBody">
                    <form class="entry-form active" id="transactionForm" method="POST"
                          data-submit-route="/add-transaction">
                        <div class="form-group">
                            <label for="amount">Amount <span class="required">*</span></label>
                            <input type="text" id="amount" placeholder="e.g. 2000" name="amount">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="category">Category</label>

                                <select id="category" name="category">
                                    <option value="income">Income</option>
                                    <option value="expense">Expense</option>
                                    <option value="other">Other</option>
                                </select>

                            </div>
                            <div class="form-group">
                                <label for="type">Type</label>

                                <select id="type" name="type">
                                    <option value="income">Income</option>
                                    <option value="expense">Expense</option>
                                    <option value="other">Other</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="date">Transaction Date</label>
                            <input id="date" type="date" placeholder="Date" name="date"/>
                        </div>
                        <div class="form-group">
                            <label for="transactionDescription">Description</label>
                            <textarea id="transactionDescription" type="text" placeholder="Write a short note...."
                                      name="description"></textarea>
                        </div>

                        <div class="form-action">
                            <button class="btn btn-secondary cancel-btn" type="button">Cancel</button>
                            <button class="btn btn-primary submit-btn" type="submit">Submit</button>
                        </div>
                    </form>

                    <form class="entry-form" id="eventForm" method="POST" data-submit-route="/add-event">
                        <div class="form-group">
                            <label for="eventName">Event Name <span class="required">*</span></label>
                            <input type="text" id="eventName" placeholder="e.g. Design Workshop" name="eventName">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="location">Location</label>
                                <input id="location" name="location" type="text" placeholder="e.g. Lahore">
                            </div>
                            <div class="form-group">
                                <label for="eventDate">Event Date</label>

                                <input id="eventDate" name="eventDate" type="date">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="eventDescription">Description</label>
                            <textarea id="eventDescription" type="text" placeholder="Write a short note...."
                                      name="description"></textarea>
                        </div>

                        <div class="form-action">
                            <button class="btn btn-secondary cancel-btn" type="button">Cancel</button>
                            <button class="btn btn-primary submit-btn" type="submit">Submit</button>
                        </div>
                    </form>

                    <form class="entry-form" id="savingForm" method="POST" data-submit-route="/add-saving">
                        <div class="form-group">
                            <label for="purpose">Saving Purpose<span class="required">*</span></label>
                            <input type="text" id="purpose" placeholder="e.g. Dream Vacation" name="purpose">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="targetAmount">Target Amount</label>
                                <input id="targetAmount" name="targetAmount" type="text" placeholder="2000">

                            </div>
                            <div class="form-group">
                                <label for="savedAmount">Saved Amount</label>

                                <input id="savedAmount" name="savedAmount" type="text" placeholder="1000">
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="targetDate">Target Date</label>
                            <input id="targetDate" type="date" placeholder="Date" name="targetDate"/>
                        </div>
                        <div class="form-group">
                            <label for="savingDescription">Description</label>
                            <textarea id="savingDescription" type="text" placeholder="Write a short note...."
                                      name="description"></textarea>
                        </div>

                        <div class="form-action">
                            <button class="btn btn-secondary cancel-btn" type="button">Cancel</button>
                            <button class="btn btn-primary submit-btn" type="submit">Submit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>


<script src="js/index.js"></script>


</body>
</html>
